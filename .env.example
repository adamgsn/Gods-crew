# ============================================================
# AI OUTBOUND VOICE SALES SYSTEM — Environment Variables
# ============================================================
# Copy this to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ============================================================

# --- Vapi (Voice AI Orchestrator) ---
# Get from Vapi Dashboard -> API Keys
VAPI_PRIVATE_API_KEY=
VAPI_PUBLIC_API_KEY=
# Create an assistant in Vapi dashboard and copy the Assistant ID
VAPI_ASSISTANT_ID=
# Imported Twilio phone number IDs from Vapi dashboard
VAPI_TEST_PHONE_NUMBER_ID=
VAPI_LIVE_PHONE_NUMBER_ID=
# Shared secret for authenticating Vapi webhook calls
VAPI_WEBHOOK_SECRET=
# Public keys for browser Talk-to-Agent widget
NEXT_PUBLIC_VAPI_PUBLIC_API_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# --- Twilio (Telephony — numbers imported into Vapi) ---
# Get from Twilio Console -> Account Info
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
# Outbound caller number in E.164 format
TWILIO_FROM_NUMBER=+16477243850

# --- Supabase (Database) ---
# Get from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use SERVICE ROLE key (bypasses RLS), NOT anon key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Stripe (Payments) ---
# Get from Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_key
# Set up webhook endpoint first, then get signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Stripe Payment Links (not Checkout Sessions)
STRIPE_LINK_650=https://buy.stripe.com/your_650_link
STRIPE_LINK_1100=https://buy.stripe.com/your_1100_link

# --- Resend (Email) ---
# Get from Resend → API Keys
RESEND_API_KEY=re_your_api_key
# Must be from a verified domain in Resend (SPF/DKIM/DMARC)
RESEND_FROM_EMAIL=sales@yourdomain.com
# Optional sender display + reply-to
RESEND_FROM_NAME=Adam at God's Cleaning Crew
RESEND_REPLY_TO_EMAIL=support@yourdomain.com
# Optional business details used in payment emails
BUSINESS_PHONE_NUMBER=+18330000000
BUSINESS_WEBSITE_URL=https://yourdomain.com

# --- App Configuration ---
# Your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Random 32+ char secret for internal endpoint auth
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=generate_a_random_32_char_string_here

# --- Vercel Cron (auto-populated by Vercel) ---
# CRON_SECRET is set automatically by Vercel for cron job auth
CRON_SECRET=

# --- Dashboard Basic Auth ---
DASHBOARD_BASIC_USER=admin
DASHBOARD_BASIC_PASS=replace_with_a_strong_password

# --- Optional Webhook Shared Secrets ---
RESEND_WEBHOOK_SECRET=placeholder
